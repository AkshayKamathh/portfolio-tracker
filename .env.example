# Copy this file to `backend/.env` for local development:
#   cp .env.example backend/.env
#
# MongoDB Atlas connection string. REQUIRED for the real backend.
# Example:
#   mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority

# Database name used by the backend.
MONGO_DB_NAME=portfolio_tracker

# Origin allowed by CORS (the Vite dev server).
FRONTEND_ORIGIN=http://localhost:5173

# URL the React frontend uses to reach the FastAPI backend.
VITE_API_BASE_URL=http://localhost:8000
